{
  "name": "best-boilerplate",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "homepage": "https://github.com/Sodiiii/projectSample",
  "repository": {
    "url": "https://github.com/Sodiiii/projectSample"
  },
  "bugs": {
    "url": "https://github.com/Sodiiii/projectSample/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "./build.sh",
    "build-pruv": "./build.sh pruv",
    "build-kaodev": "./build.sh kaodev",
    "build-test": "./build.sh test",
    "build-production": "./build.sh",
    "preview-pruv": "vite preview --mode pruv",
    "preview-kaodev": "vite preview --mode kaodev",
    "lint": "eslint . && stylelint \"src/**/*.scss\"",
    "lint:fix": "eslint . --fix && stylelint \"src/**/*.scss\" --fix",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "zip": "zip -r project_$(date +%d-%m-%y).zip build/",
    "prepare": "husky"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@hookform/resolvers": "^5.1.1",
    "@reduxjs/toolkit": "^2.8.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.12",
    "@tinkerbells/xenon-ui": "^0.0.88",
    "@tiptap/extension-color": "^2.25.0",
    "@tiptap/extension-heading": "^2.25.0",
    "@tiptap/extension-highlight": "^2.25.0",
    "@tiptap/extension-paragraph": "^2.25.0",
    "@tiptap/extension-placeholder": "^2.25.0",
    "@tiptap/extension-text-align": "^2.25.0",
    "@tiptap/extension-text-style": "^2.25.0",
    "@tiptap/react": "^2.25.0",
    "@tiptap/starter-kit": "^2.25.0",
    "dayjs": "^1.11.19",
    "nuqs": "^2.4.3",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-error-boundary": "^5.0.0",
    "react-hook-form": "^7.55.0",
    "react-redux": "^9.2.0",
    "react-router": "^7.6.3",
    "redux-persist": "^6.0.0",
    "sonner": "^2.0.6",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.0.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.16.2",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.30.1",
    "@faker-js/faker": "^9.9.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.30.1",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "msw": "^2.10.3",
    "prettier": "^3.6.2",
    "rollup-plugin-visualizer": "^6.0.3",
    "stylelint": "^16.21.1",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard-scss": "^15.0.1",
    "stylelint-declaration-strict-value": "^1.10.11",
    "stylelint-scss": "^6.12.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "typescript-plugin-css-modules": "^5.1.0",
    "vite": "^7.0.3"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
